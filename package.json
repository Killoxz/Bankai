{
  "name": "bankai",
  "version": "1.0.0",
  "private": true,
  "description": "Bankai — a modern anime streaming platform. Browse trending shows, track your watchlist, and pick up where you left off.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
