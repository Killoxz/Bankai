# ---- App ----
NEXT_PUBLIC_APP_NAME=Bankai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Data source ----
# "mock"   -> runs fully offline with bundled demo data (default, no keys needed)
# "anilist"-> live AniList GraphQL
# "jikan"  -> live Jikan (MyAnimeList) REST
DATA_PROVIDER=mock
NEXT_PUBLIC_DATA_PROVIDER=mock

# ---- Streaming (aniwatch-api / HiAnime) ----
# Self-host: https://github.com/ghoshRitesh12/aniwatch-api
# Deploy free on Railway/Render, then paste your URL here.
# Without this, a placeholder test stream plays instead of real episodes.
STREAMING_API_URL=

# Optional: TMDB for trailers/backdrops
TMDB_API_KEY=

# ---- Database (Prisma / PostgreSQL) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bankai?schema=public"

# ---- NextAuth (Auth.js v5) ----
# Generate: openssl rand -base64 32
AUTH_SECRET=changeme-in-production
AUTH_TRUST_HOST=true

# OAuth providers (all optional — leave blank to hide that button)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- Redis (optional caching) ----
REDIS_URL=
